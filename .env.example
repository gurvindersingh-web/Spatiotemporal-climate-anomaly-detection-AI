# CDS API credentials (for ERA5 data fetching)
CDS_API_URL=https://cds.climate.copernicus.eu/api
CDS_API_KEY=your_api_key_here

# Gemini API key (for LLM explanations)
GEMINI_API_KEY=your_gemini_api_key_here

# Redis (for caching /detect results)
REDIS_URL=redis://localhost:6379/0

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ML model configuration
VAE_LATENT_DIM=16
VAE_HIDDEN_DIM=64
ANOMALY_THRESHOLD_WATCH=0.7
ANOMALY_THRESHOLD_WARNING=0.8
ANOMALY_THRESHOLD_EXTREME=0.9
FUSION_WEIGHT_VAE=0.6
FUSION_WEIGHT_IF=0.4

# Data paths
DATA_CACHE_DIR=./data/cache
MODEL_CACHE_DIR=./models

# Frontend (set in frontend/.env or as VITE_ prefixed vars)
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000/ws/live
