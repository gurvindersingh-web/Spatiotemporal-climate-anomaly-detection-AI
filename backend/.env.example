# Server
PORT=3001
NODE_ENV=development

# NASA POWER API (no key needed, but respect rate limits)
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point

# NOAA CDO API
NOAA_CDO_TOKEN=your_noaa_cdo_token_here
NOAA_CDO_BASE_URL=https://www.ncdc.noaa.gov/cdo-web/api/v2

# OpenWeatherMap API
OWM_API_KEY=your_openweathermap_api_key_here
OWM_BASE_URL=https://api.openweathermap.org/data/2.5

# Anomaly Detection
ANOMALY_THRESHOLD=2.0
ANOMALY_WATCH=1.5
ANOMALY_WARNING=2.0
ANOMALY_EXTREME=3.0

# Scheduling (cron expressions)
CRON_HIGH_FREQ=*/10 * * * *
CRON_MEDIUM_FREQ=0 */6 * * *
CRON_LOW_FREQ=0 2 * * *

# Monitored cities (JSON array of {name, lat, lng})
MONITORED_CITIES=[{"name":"Delhi","lat":28.6,"lng":77.2},{"name":"Tokyo","lat":35.7,"lng":139.7},{"name":"Phoenix","lat":33.4,"lng":-112.1},{"name":"Cairo","lat":30.0,"lng":31.2},{"name":"São Paulo","lat":-23.5,"lng":-46.6},{"name":"London","lat":51.5,"lng":-0.1},{"name":"Sydney","lat":-33.9,"lng":151.2},{"name":"Nairobi","lat":-1.3,"lng":36.8}]

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
